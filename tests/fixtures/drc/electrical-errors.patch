# DRC fixture: signal level mismatch

template Mic {
  meta {
    kind: "device"
  }
  ports { Out: out(XLR) [mic_level] }
}

template LineDevice {
  meta {
    kind: "device"
  }
  ports {
    Out: out(XLR) [line_level]
    In: in(XLR) [line_level]
  }
}

template Amp {
  meta {
    kind: "device"
  }
  ports {
    Out: out(SpeakON) [speaker_level]
    In: in(SpeakON) [speaker_level]
  }
}

instance M is Mic
instance D is LineDevice
instance A is Amp

# Valid — same level
connect D.Out -> D.In

# E01 — speaker_level to line_level (destructive level gap)
connect A.Out -> D.In
