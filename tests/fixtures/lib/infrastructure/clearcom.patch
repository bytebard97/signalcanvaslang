# ============================================================
# Clear-Com Intercom Systems
# Eclipse HX matrices, V-Series panels, and RS beltpacks
# ============================================================

template Eclipse_HX_Omega {
  meta {
    kind: "device"
    manufacturer: "Clear-Com"
    model: "Eclipse HX-Omega"
    category: "Intercom Matrix"
    protocols: "IVC, AES67, Dante, MADI"
    ports_capacity: "496"
  }
  ports {
    LAN[1..2]: io(RJ45)
    GPI: in(DB25)
    GPO: out(DB25)
    Partyline[1..4]: io(XLR)
    Serial: io(virtual)
  }
  slot Card_Slot[1..15]: Interface_Card
}

