# ============================================================
# Crestron — AV-over-IP Endpoints
# Standard library templates for Crestron DM NVX devices.
# ============================================================

# --- DM-NVX-360: AV-over-IP Endpoint (Encoder/Decoder) ------

template DM_NVX_360 {
  meta {
    kind: "device"
    manufacturer: "Crestron"
    model: "DM-NVX-360"
    category: "AV Bridge"
  }
  ports {
    HDMI_In: in(HDMI) [UHD]
    HDMI_Out: out(HDMI) [UHD]
    Network_1: io(RJ45) [DM_NVX, PoE]
    Network_2: io(RJ45) [Ethernet]
    Network_3: io(RJ45) [Ethernet]
    Network_SFP: io(SFP) [DM_NVX]
    Audio_IO: io(Euroblock) [Analogue]
    USB_Host: io(USB) [USB_2]
    RS232: io(Euroblock) [RS232]
    IR[1..2]: out(Euroblock) [IR]
  }
}

# --- CP4-N: Control Processor --------------------------------

template CP4_N {
  meta {
    kind: "device"
    manufacturer: "Crestron"
    model: "CP4-N"
    category: "Control Processor"
  }
  ports {
    LAN: io(RJ45) [Ethernet]
    Control_Subnet: io(RJ45) [Ethernet]
    COM[1..3]: io(Euroblock) [RS232]
    IR_Out[1..8]: out(Euroblock) [IR]
    Relay[1..8]: out(Euroblock) [Relay]
    Versiport[1..8]: io(Euroblock) [GPIO]
  }
}
