# ============================================================
# RTS Intercom Systems
# ADAM-M matrix and KP-5032 OMNEO panel
# ============================================================

template ADAM_M {
  meta {
    kind: "device"
    manufacturer: "RTS"
    model: "ADAM-M"
    category: "Intercom Matrix"
    protocols: "OMNEO, AES67, Dante, RVON"
    ports_capacity: "256"
  }
  ports {
    Controller_In[1..2]: in(RJ45) [AES67, Dante]
    Controller_Out[1..2]: out(RJ45) [AES67, Dante]
    Serial: io(virtual)
    GPIO: io(DB25)
  }
  slot Card_Slot[1..8]: Interface_Card
}

template KP_5032 {
  meta {
    kind: "device"
    manufacturer: "RTS"
    model: "KP-5032"
    category: "Intercom Panel"
    protocols: "OMNEO, RVON"
  }
  ports {
    Headset: io(XLR)
    LAN_Pri_In: in(RJ45) [Dante, AES67, primary]
    LAN_Pri_Out: out(RJ45) [Dante, AES67, primary]
    LAN_Sec_In: in(RJ45) [Dante, AES67, secondary]
    LAN_Sec_Out: out(RJ45) [Dante, AES67, secondary]
    Mic_In: in(XLR)
  }
}
