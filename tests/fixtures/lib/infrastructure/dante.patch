# ============================================================
# Dante Audio Interfaces and Converters
# Analog, AES3, and modular converters for Dante/AES67 networks
# ============================================================

template Focusrite_RedNet_A16R {
  meta {
    kind: "device"
    manufacturer: "Focusrite"
    model: "RedNet A16R MkII"
    category: "Audio Interface"
    protocols: "Dante, AES67, ST 2110-30"
  }
  ports {
    Dante_Pri_In[1..16]: in(etherCON) [Dante, primary]
    Dante_Pri_Out[1..16]: out(etherCON) [Dante, primary]
    Analog_In[1..2]: in(DB25) [analog, line_level]
    Analog_Out[1..2]: out(DB25) [analog, line_level]
    AES_In: in(XLR) [AES3]
    AES_Out: out(XLR) [AES3]
    WC_In: in(BNC_75) [WordClock]
    WC_Out: out(BNC_75) [WordClock]
  }
  bridge Analog_In -> Dante_Pri_Out
  bridge Dante_Pri_In -> Analog_Out
}

template Focusrite_RedNet_D16R {
  meta {
    kind: "device"
    manufacturer: "Focusrite"
    model: "RedNet D16R MkII"
    category: "Audio Interface"
    protocols: "Dante, AES67, AES3"
  }
  ports {
    Dante_Pri_In[1..16]: in(etherCON) [Dante, primary]
    Dante_Pri_Out[1..16]: out(etherCON) [Dante, primary]
    AES3_In[1..2]: in(DB25) [AES3]
    AES3_Out[1..2]: out(DB25) [AES3]
    AES_Alt_In: in(XLR) [AES3]
    AES_Alt_Out: out(XLR) [AES3]
    WC_In: in(BNC_75) [WordClock]
    WC_Out: out(BNC_75) [WordClock]
  }
  bridge AES3_In -> Dante_Pri_Out
  bridge Dante_Pri_In -> AES3_Out
}

template Audinate_AVIO_Analog {
  meta {
    kind: "device"
    manufacturer: "Audinate"
    model: "AVIO Analog"
    category: "Audio Interface"
    protocols: "Dante"
  }
  ports {
    Dante_Net_In: in(RJ45) [Dante, PoE]
    Dante_Net_Out: out(RJ45) [Dante, PoE]
    Analog_In: in(XLR) [analog, line_level]
    Analog_Out: out(XLR) [analog, line_level]
  }
  bridge Analog_In -> Dante_Net_Out
  bridge Dante_Net_In -> Analog_Out
}

template Audinate_AVIO_AES3 {
  meta {
    kind: "device"
    manufacturer: "Audinate"
    model: "AVIO AES3"
    category: "Audio Interface"
    protocols: "Dante"
  }
  ports {
    Dante_Net: io(RJ45) [Dante, PoE]
    AES_In: in(XLR) [AES3, SRC]
    AES_Out: out(XLR) [AES3]
  }
  bridge AES_In -> Dante_Net
  bridge Dante_Net -> AES_Out
}

template DirectOut_PRODIGY_MC {
  meta {
    kind: "device"
    manufacturer: "DirectOut"
    model: "PRODIGY.MC"
    category: "Audio Converter"
    protocols: "MADI, Dante, RAVENNA, AES67, ST 2110-30"
  }
  ports {
    Network_Pri_In[1..64]: in(etherCON) [Dante, AES67, primary]
    Network_Pri_Out[1..64]: out(etherCON) [Dante, AES67, primary]
    MADI_1_In[1..64]: in(BNC_75) [MADI, ch64]
    MADI_1_Out[1..64]: out(BNC_75) [MADI, ch64]
    MADI_2_In[1..64]: in(SFP) [MADI, ch64]
    MADI_2_Out[1..64]: out(SFP) [MADI, ch64]
  }
  slot IO_Slot[1..8]: IO_Module
}
