# ============================================================
# Audio Word Clocks and Frequency Distribution
# Master clocks for studio and live sound environments
# ============================================================

template Antelope_OCX_HD {
  meta {
    kind: "device"
    manufacturer: "Antelope Audio"
    model: "OCX HD"
    category: "Master Clock"
    protocols: "Word Clock, AES3, S/PDIF, 10MHz"
  }
  ports {
    WC_Out[1..10]: out(BNC_75) [WordClock]
    AES_Out[1..4]: out(XLR) [AES3]
    WC_In[1..2]: in(BNC_75) [WordClock]
    Video_In: in(BNC_75) [BlackBurst, TriLevel]
    Atomic_In: in(BNC_75)
    AES_In: in(XLR) [AES3]
  }
}

