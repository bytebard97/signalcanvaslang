# ============================================================
# Riedel Communications
# Artist intercom matrices, SmartPanels, Bolero wireless,
# and MediorNet fiber transport nodes
# ============================================================

template Artist_1024 {
  meta {
    kind: "device"
    manufacturer: "Riedel"
    model: "Artist-1024"
    category: "Intercom Matrix"
    protocols: "AES67, Dante, MADI, Artist Fiber, ST 2110-30"
    ports_capacity: "1024"
  }
  ports {
    Mgmt[1..2]: io(RJ45)
    GPIO: io(DB25)
  }
  slot UIC_Slot[1..8]: UIC_128
  slot NIC_Slot[1..2]: NIC_Fiber
}

template Artist_128 {
  meta {
    kind: "device"
    manufacturer: "Riedel"
    model: "Artist-128"
    category: "Intercom Matrix"
    protocols: "Artist Fiber, AVB, AES67, MADI"
    ports_capacity: "128"
  }
  ports {
    Mgmt: io(RJ45)
  }
  slot Client_Slot[1..16]: Client_Card
  slot Controller_Bay[1..2]: Controller_Module
}

template RSP_1232HL {
  meta {
    kind: "device"
    manufacturer: "Riedel"
    model: "RSP-1232HL"
    category: "Intercom Panel"
    protocols: "ST 2110-30, AES67, Dante"
  }
  ports {
    LAN_Pri_In: in(RJ45) [AES67, Dante, primary]
    LAN_Pri_Out: out(RJ45) [AES67, Dante, primary]
    LAN_Sec_In: in(RJ45) [AES67, Dante, secondary]
    LAN_Sec_Out: out(RJ45) [AES67, Dante, secondary]
    Headset[1..2]: io(XLR_5)
  }
}

template Bolero {
  meta {
    kind: "device"
    manufacturer: "Riedel"
    model: "Bolero"
    category: "Intercom Beltpack"
    protocols: "DECT, IP"
  }
  ports {
    Headset: io(XLR)
  }
}

template MediorNet_MicroN {
  meta {
    kind: "device"
    manufacturer: "Riedel"
    model: "MediorNet MicroN"
    category: "Fiber Transport"
    protocols: "3G-SDI, MediorNet 10G, ST 2110"
  }
  ports {
    SDI_In[1..12]: in(BNC_75) [SDI]
    SDI_Out[1..12]: out(BNC_75) [SDI]
    MediorNet_Link_In[1..8]: in(SFP_Plus)
    MediorNet_Link_Out[1..8]: out(SFP_Plus)
    Sync_In[1..2]: in(BNC_75) [BlackBurst, TriLevel]
    Sync_Out[1..2]: out(BNC_75) [BlackBurst, TriLevel]
    LAN[1..2]: io(RJ45)
  }
}

template MediorNet_FusioN {
  meta {
    kind: "device"
    manufacturer: "Riedel"
    model: "MediorNet FusioN"
    category: "Media Network Node"
    protocols: "ST 2110, ST 2022-6, HDMI"
  }
  ports {
    Media_In[1..2]: in(SFP_Plus) [SMPTE_2110]
    Media_Out[1..2]: out(SFP_Plus) [SMPTE_2110]
    Control: io(RJ45)
  }
}
