# ============================================================
# Sync Generators — Master Reference for Video and Audio
# Black Burst, Tri-Level, Word Clock, and PTP sources
# ============================================================

template AJA_GEN10 {
  meta {
    kind: "device"
    manufacturer: "AJA"
    model: "GEN10"
    category: "Sync Generator"
    protocols: "Black Burst, Tri-Level, AES-11"
  }
  ports {
    Sync_Out_Grp1[1..4]: out(BNC_75) [BlackBurst, TriLevel]
    Sync_Out_Grp2[1..2]: out(BNC_75) [BlackBurst, TriLevel]
    AES11_Out: out(BNC_75) [AES3, clk_48kHz]
  }
}

template Evertz_5601MSC {
  meta {
    kind: "device"
    manufacturer: "Evertz"
    model: "5601MSC"
    category: "Master Clock"
    protocols: "Black Burst, Tri-Level, Word Clock, PTP, NTP, LTC"
  }
  ports {
    Sync_Out[1..6]: out(BNC_75) [BlackBurst, TriLevel]
    WC_Out: out(BNC_75) [WordClock, clk_48kHz]
