# ============================================================
# DiGiCo DMI (Multichannel Interface) Expansion Cards
#
# Slot format: DMI_Card
# Used in: DiGiCo S-Series, SD12, Quantum consoles, Orange Box
# High-bandwidth cards optimized for 64+ channels at 96 kHz.
# ============================================================

template DMI_DANTE64 {
  meta {
    manufacturer: "DiGiCo"
    model: "DMI-DANTE64@96"
    kind: "card"
    fits: "DMI_Card"
  }
  ports {
    Dante_In[1..64]: in(etherCON) [Dante]
    Dante_Out[1..64]: out(etherCON) [Dante]
  }
}

