# ============================================================
# Soundcraft D21m + Si Option Expansion Cards
#
# Slot formats:
#   D21m_Card — Vi Series Local Racks and stageboxes (Studer heritage)
#   Si_Option_Card — Si Expression / Performer / Impact option slots
#
# Used in: Soundcraft Vi, Si series consoles
# ============================================================

# --- Vi Series D21m Cards -------------------------------------

template D21m_Line_In {
  meta {
    manufacturer: "Soundcraft"
    model: "RS2425SP"
    kind: "card"
    fits: "D21m_Card"
  }
  ports {
    Line_In[1..8]: in(Dsub_25) [analog, line_level]
  }
}

template D21m_Line_Out {
  meta {
    manufacturer: "Soundcraft"
    model: "RS2424SP"
    kind: "card"
    fits: "D21m_Card"
  }
  ports {
    Line_Out[1..8]: out(Dsub_25) [analog, line_level]
  }
}

