# ============================================================
# Yamaha Mini-YGDAI (MY) Expansion Cards
#
# Slot format: MY_Card (Mini-YGDAI)
# Used in: Yamaha CL, QL, PM, RIVAGE consoles
# Each card fits a single MY slot and provides analog, digital,
# or network I/O to the host console.
# ============================================================

# --- Proprietary Analog Cards --------------------------------

template MY8_AD96 {
  meta {
    manufacturer: "Yamaha"
    model: "MY8-AD96"
    kind: "card"
    fits: "MY_Card"
  }
  ports {
    Analog_In[1..8]: in(Dsub_25) [analog, line_level]
  }
}

template MY8_DA96 {
  meta {
    manufacturer: "Yamaha"
    model: "MY8-DA96"
    kind: "card"
    fits: "MY_Card"
  }
  ports {
    Analog_Out[1..8]: out(Dsub_25) [analog, line_level]
  }
}

