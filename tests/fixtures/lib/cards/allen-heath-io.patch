# ============================================================
# Allen & Heath I/O Port + SQ Option Expansion Cards
#
# Slot formats:
#   IO_Port_Card — dLive MixRack / Avantis I/O Ports
#   SQ_Option_Card — SQ / AHM option slots
#
# Used in: dLive, Avantis, SQ, AHM series
# ============================================================

# --- dLive / Avantis I/O Port Cards --------------------------

template M_DL_DANTE128_A {
  meta {
    manufacturer: "Allen & Heath"
    model: "M-DL-DANTE128-A"
    kind: "card"
    fits: "IO_Port_Card"
  }
  ports {
    Dante_In[1..128]: in(etherCON) [Dante]
    Dante_Out[1..128]: out(etherCON) [Dante]
  }
}

