# ============================================================
# Focusrite Professional Audio — Standard Library Templates
# RedNet Dante Audio Interfaces
# ============================================================

template RedNet_A16R_MkII {
  meta {
    kind: "device"
    manufacturer: "Focusrite"
    model: "RedNet A16R MkII"
    category: "Dante Interface"
  }
  ports {
    Dante_Pri_In[1..16]: in(etherCON) [Dante, primary]
    Dante_Pri_Out[1..16]: out(etherCON) [Dante, primary]
    Dante_Sec_In[1..16]: in(etherCON) [Dante, secondary]
    Dante_Sec_Out[1..16]: out(etherCON) [Dante, secondary]
    Analog_In[1..16]: in(DB25) [analog, line_level]
    Analog_Out[1..16]: out(DB25) [analog, line_level]
    WordClock_In: in(BNC_75) [WordClock]
    WordClock_Out: out(BNC_75) [WordClock]
    MIDI_In: in(XLR_5) [MIDI]
    MIDI_Out: out(XLR_5) [MIDI]
  }
  bridge Analog_In -> Dante_Pri_Out
  bridge Dante_Pri_In -> Analog_Out
}

template RedNet_D16R_MkII {
  meta {
    kind: "device"
    manufacturer: "Focusrite"
    model: "RedNet D16R MkII"
    category: "Dante Interface"
  }
  ports {
    Dante_Pri_In[1..16]: in(etherCON) [Dante, primary]
    Dante_Pri_Out[1..16]: out(etherCON) [Dante, primary]
    Dante_Sec_In[1..16]: in(etherCON) [Dante, secondary]
    Dante_Sec_Out[1..16]: out(etherCON) [Dante, secondary]
    AES_In[1..16]: in(DB25) [AES3, SRC]
    AES_Out[1..16]: out(DB25) [AES3]
    WordClock_In: in(BNC_75) [WordClock]
    WordClock_Out: out(BNC_75) [WordClock]
    MIDI_In: in(XLR_5) [MIDI]
    MIDI_Out: out(XLR_5) [MIDI]
  }
  bridge AES_In -> Dante_Pri_Out
  bridge Dante_Pri_In -> AES_Out
}
