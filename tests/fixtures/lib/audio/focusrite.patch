# ============================================================
# Focusrite Professional Audio — Standard Library Templates
# RedNet Dante Audio Interfaces
# ============================================================

template RedNet_A16R_MkII {
  meta {
    manufacturer: "Focusrite"
    model: "RedNet A16R MkII"
    category: "Dante Interface"
  }
  ports {
    Dante_Pri: io(etherCON) [Dante, primary]
    Dante_Sec: io(etherCON) [Dante, secondary]
    Analog_In[1..16]: in(XLR) [analog, line_level]
    Analog_Out[1..16]: out(XLR) [analog, line_level]
    WordClock_In: in(BNC_75) [WordClock]
    WordClock_Out: out(BNC_75) [WordClock]
    MIDI_In: in(XLR_5) [MIDI]
    MIDI_Out: out(XLR_5) [MIDI]
  }
  bridge Analog_In -> Dante_Pri
  bridge Dante_Pri -> Analog_Out
}

template RedNet_D16R_MkII {
  meta {
    manufacturer: "Focusrite"
    model: "RedNet D16R MkII"
    category: "Dante Interface"
  }
  ports {
    Dante_Pri: io(etherCON) [Dante, primary]
    Dante_Sec: io(etherCON) [Dante, secondary]
    AES_In[1..16]: in(DB25) [AES3, SRC]
    AES_Out[1..16]: out(DB25) [AES3]
    WordClock_In: in(BNC_75) [WordClock]
    WordClock_Out: out(BNC_75) [WordClock]
    MIDI_In: in(XLR_5) [MIDI]
    MIDI_Out: out(XLR_5) [MIDI]
  }
  bridge AES_In -> Dante_Pri
  bridge Dante_Pri -> AES_Out
}
