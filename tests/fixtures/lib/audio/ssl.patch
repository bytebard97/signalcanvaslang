# ============================================================
# Solid State Logic (SSL) — Standard Library Templates
# SSL Live Series Consoles
# ============================================================

# --- SSL Live L550 Plus ---------------------------------------

template Live_L550_Plus {
  meta {
    kind: "device"
    manufacturer: "SSL"
    model: "Live L550 Plus"
    category: "Console"
  }
  ports {
    # MADI I/O (12 coaxial = 6 in + 6 out, 4 optical = 2 in + 2 out)
    MADI_BNC_In[1..6]: in(BNC_75) [MADI]
    MADI_BNC_Out[1..6]: out(BNC_75) [MADI]
    MADI_Optical_In[1..2]: in(SC_Optical) [MADI]
    MADI_Optical_Out[1..2]: out(SC_Optical) [MADI]
    MADI_FX_Optical_In: in(SC_Optical) [MADI]
    MADI_FX_Optical_Out: out(SC_Optical) [MADI]
    MIDI_In: in(XLR_5) [MIDI]
    MIDI_Out: out(XLR_5) [MIDI]
    WordClock_In: in(BNC_75) [WordClock]
    WordClock_Out: out(BNC_75) [WordClock]
    Network: io(RJ45) [Ethernet]
  }
  bridge MADI_BNC_In -> MADI_BNC_Out
}

# --- SSL Live L650 --------------------------------------------

template Live_L650 {
  meta {
    kind: "device"
    manufacturer: "SSL"
    model: "Live L650"
    category: "Console"
  }
  ports {
    # MADI I/O (6 coaxial = 3 in + 3 out, 2 optical = 1 in + 1 out)
    MADI_BNC_In[1..3]: in(BNC_75) [MADI]
    MADI_BNC_Out[1..3]: out(BNC_75) [MADI]
    MADI_Optical_In: in(SC_Optical) [MADI]
    MADI_Optical_Out: out(SC_Optical) [MADI]
    MADI_FX_Optical_In: in(SC_Optical) [MADI]
    MADI_FX_Optical_Out: out(SC_Optical) [MADI]
    MIDI_In: in(XLR_5) [MIDI]
    MIDI_Out: out(XLR_5) [MIDI]
    WordClock_In: in(BNC_75) [WordClock]
    WordClock_Out: out(BNC_75) [WordClock]
    Network: io(RJ45) [Ethernet]
  }
}
