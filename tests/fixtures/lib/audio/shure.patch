# --- PSM In-Ear Monitor Systems -------------------------------

template PSM1000_P10T {
  meta {
    kind: "device"
    manufacturer: "Shure"
    model: "PSM1000 P10T"
    category: "IEM Transmitter"
  }
  ports {
    Audio_In[1..2]: in(XLR) [analog, line_level]
    Loop_Out[1..2]: out(TRS) [analog, line_level, loop]
    Antenna_A: out(BNC_50) [RF]
    Antenna_B: out(BNC_50) [RF]
    Network: io(RJ45)
  }
  bridge Audio_In -> Antenna_A
}

template PSM900_P9T {
  meta {
    kind: "device"
    manufacturer: "Shure"
    model: "PSM900 P9T"
    category: "IEM Transmitter"
  }
  ports {
    Audio_In[1..2]: in(XLR) [analog, line_level]
    Loop_Out[1..2]: out(TRS) [analog, line_level, loop]
    Antenna: out(BNC_50) [RF]
  }
  bridge Audio_In -> Antenna
}

