# --- dLive Series ---------------------------------------------

template dLive_S7000 {
  meta {
    manufacturer: "Allen and Heath"
    model: "dLive S7000"
    category: "Console"
  }
  ports {
    GigaACE_Pri: io(etherCON) [GigaACE, primary]
    GigaACE_Sec: io(etherCON) [GigaACE, redundant]
    Mic_In[1..8]: in(XLR) [analog, mic_level, phantom_48V]
    Line_Out[1..8]: out(XLR) [analog, line_level]
    AES_In[1..4]: in(XLR) [AES3, SRC]
    AES_Out[1..6]: out(XLR) [AES3]
    WordClock_In: in(BNC_75) [WordClock]
    WordClock_Out: out(BNC_75) [WordClock]
    MIDI_In: in(XLR_5) [MIDI]
    MIDI_Out: out(XLR_5) [MIDI]
  }
  slot IO_Port[1..2]: AH_IO_Card
  bridge Mic_In -> GigaACE_Pri
}

