# ============================================================
# Sennheiser Professional Audio — Standard Library Templates
# EW-DX Series, Digital 6000 Series
# ============================================================

# --- EW-DX Series ---------------------------------------------

template EW_D_EM {
  meta {
    kind: "device"
    manufacturer: "Sennheiser"
    model: "EW-DX EM 4 Dante"
    category: "Wireless Receiver"
  }
  ports {
    Antenna_A: in(BNC_50) [RF]
    Antenna_B: in(BNC_50) [RF]
    Analog_Out[1..4]: out(XLR) [analog, line_level]
    Headphone_Out[1..4]: out(TRS) [analog, line_level]
    Dante_Pri_In[1..4]: in(RJ45) [Dante, AES67, primary]
    Dante_Pri_Out[1..4]: out(RJ45) [Dante, AES67, primary]
    Dante_Sec_In[1..4]: in(RJ45) [Dante, AES67, secondary]
    Dante_Sec_Out[1..4]: out(RJ45) [Dante, AES67, secondary]
    Network_Control: io(RJ45)
    Network_Control_2: io(RJ45)
    WordClock_In: in(BNC_75) [WordClock]
    WordClock_Thru: out(BNC_75) [WordClock]
  }
  bridge Antenna_A -> Analog_Out
  bridge Antenna_A -> Dante_Pri_Out
}

# --- Digital 6000 Series --------------------------------------

template Digital_6000_EM6000 {
  meta {
    kind: "device"
    manufacturer: "Sennheiser"
    model: "Digital 6000 EM 6000"
    category: "Wireless Receiver"
  }
  ports {
    Antenna_A: in(BNC_50) [RF]
    Antenna_B: in(BNC_50) [RF]
    Analog_Out[1..2]: out(XLR) [analog, line_level]
    AES_Out: out(XLR) [AES3]
    Dante_Pri_In[1..2]: in(RJ45) [Dante, AES67, primary]
    Dante_Pri_Out[1..2]: out(RJ45) [Dante, AES67, primary]
    Dante_Sec_In[1..2]: in(RJ45) [Dante, AES67, secondary]
    Dante_Sec_Out[1..2]: out(RJ45) [Dante, AES67, secondary]
    WordClock_In: in(BNC_75) [WordClock]
    WordClock_Out: out(BNC_75) [WordClock]
    Network_Control: io(RJ45)
  }
  bridge Antenna_A -> Analog_Out
  bridge Antenna_A -> Dante_Pri_Out
}
