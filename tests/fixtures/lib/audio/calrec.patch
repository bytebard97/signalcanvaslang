# ============================================================
# Calrec Audio — Standard Library Templates
# Apollo, Brio, Artemis Beam — Broadcast Consoles
# ============================================================

# --- Calrec Apollo --------------------------------------------

template Calrec_Apollo {
  meta {
    kind: "device"
    manufacturer: "Calrec"
    model: "Apollo"
    category: "Console"
  }
  ports {
    Hydra2_In[1..2]: in(etherCON) [Hydra2]
    Hydra2_Out[1..2]: out(etherCON) [Hydra2]
    Network: io(RJ45) [Ethernet]
  }
  slot IO_Slot[1..4]: Calrec_IO_Card
}

# --- Calrec Brio 36 ------------------------------------------

template Calrec_Brio_36 {
  meta {
    kind: "device"
    manufacturer: "Calrec"
    model: "Brio 36"
    category: "Console"
  }
  ports {
    Mic_In[1..24]: in(XLR) [analog, mic_level]
    Line_Out[1..16]: out(XLR) [analog, line_level]
    AES_In[1..8]: in(XLR) [AES3]
    AES_Out[1..8]: out(XLR) [AES3]
    MIDI_In: in(XLR_5) [MIDI]
    MIDI_Out: out(XLR_5) [MIDI]
    Network: io(RJ45) [Ethernet]
  }
  slot Expansion_Slot[1..3]: Calrec_Option_Card
  bridge Mic_In -> AES_Out
}

# --- Calrec Artemis Beam -------------------------------------

template Calrec_Artemis_Beam {
  meta {
    kind: "device"
    manufacturer: "Calrec"
    model: "Artemis Beam"
    category: "Console"
  }
  ports {
    Hydra2_In[1..2]: in(etherCON) [Hydra2]
    Hydra2_Out[1..2]: out(etherCON) [Hydra2]
    Network: io(RJ45) [Ethernet]
  }
  slot IO_Slot[1..6]: Calrec_IO_Card
}
