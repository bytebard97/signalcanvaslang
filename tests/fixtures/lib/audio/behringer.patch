# ============================================================
# Behringer Professional Audio — Standard Library Templates
# X32 Console, S16 / S32 Digital Stageboxes
# ============================================================

# --- X32 Console ----------------------------------------------

template X32 {
  meta {
    kind: "device"
    manufacturer: "Behringer"
    model: "X32"
    category: "Console"
  }
  ports {
    # Analog I/O
    Mic_In[1..32]: in(XLR) [analog, mic_level]
    Line_Out[1..16]: out(XLR) [analog, line_level]
    Aux_In[1..6]: in(TRS_14) [analog, line_level]
    Aux_Out[1..6]: out(TRS_14) [analog, line_level]
    RCA_In[1..2]: in(RCA) [analog, line_level]
    RCA_Out[1..2]: out(RCA) [analog, line_level]

    # AES50 digital snakes
    AES50_A_In[1..48]: in(etherCON) [AES50]
    AES50_A_Out[1..48]: out(etherCON) [AES50]
    AES50_B_In[1..48]: in(etherCON) [AES50]
    AES50_B_Out[1..48]: out(etherCON) [AES50]

    # Digital audio
    AES_Out: out(XLR) [AES3]
    ULTRANET_Out[1..16]: out(RJ45) [ULTRANET]
    USB_IO[1..32]: io(USB) [USB_Audio]

    # Control and sync
    MIDI_In: in(XLR_5) [MIDI]
    MIDI_Out: out(XLR_5) [MIDI]
    Ethernet: io(RJ45) [Ethernet]
    WordClock_Out: out(BNC_75) [WordClock]
  }
  slot Expansion_Slot: X32_Card
  bridge Mic_In -> AES50_A_Out
}

# --- S16 Stagebox ---------------------------------------------

template S16 {
  meta {
    kind: "device"
    manufacturer: "Behringer"
    model: "S16"
    category: "Stagebox"
  }
  ports {
    # Analog I/O
    Mic_In[1..16]: in(XLR) [analog, mic_level]
    Line_Out[1..8]: out(XLR) [analog, line_level]

    # AES50 digital snakes
    AES50_A_In[1..48]: in(etherCON) [AES50]
    AES50_A_Out[1..48]: out(etherCON) [AES50]
    AES50_B_In[1..48]: in(etherCON) [AES50]
    AES50_B_Out[1..48]: out(etherCON) [AES50]

    # Digital audio
    ADAT_Out[1..16]: out(TOSLINK) [ADAT]
    ULTRANET_Out[1..16]: out(RJ45) [ULTRANET]

    # Control
    MIDI_In: in(XLR_5) [MIDI]
    MIDI_Out: out(XLR_5) [MIDI]
  }
  bridge Mic_In -> AES50_A_Out
  bridge AES50_A_In -> Line_Out
}

