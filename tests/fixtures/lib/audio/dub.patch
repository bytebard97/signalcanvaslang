# ============================================================
# d&b audiotechnik Professional Audio — Standard Library Templates
# DS10 Audio Network Bridge
# ============================================================

template db_DS10 {
  meta {
    kind: "device"
    manufacturer: "d&b audiotechnik"
    model: "DS10"
    category: "Audio Network Bridge"
  }
  ports {
    AES_Out[1..16]: out(XLR) [AES3]
    AES_In[1..4]: in(XLR) [AES3]
    Dante_Pri: io(etherCON) [Dante, primary]
    Dante_Sec: io(etherCON) [Dante, secondary]
    Ethernet[1..5]: io(etherCON) [Ethernet]
  }
  bridge Dante_Pri -> AES_Out
  bridge AES_In -> Dante_Pri
}
