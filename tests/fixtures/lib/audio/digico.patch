template SD_Rack {
  meta {
    manufacturer: "DiGiCo"
    model: "SD-Rack"
    category: "Stagebox"
  }
  ports {
    Optocore_A_In: in(OpticalCon) [Optocore]
    Optocore_A_Out: out(OpticalCon) [Optocore]
    Optocore_B_In: in(OpticalCon) [Optocore]
    Optocore_B_Out: out(OpticalCon) [Optocore]
    MADI_A_In[1..64]: in(BNC_75) [MADI]
    MADI_A_Out[1..64]: out(BNC_75) [MADI]
    MADI_B_In[1..64]: in(BNC_75) [MADI]
