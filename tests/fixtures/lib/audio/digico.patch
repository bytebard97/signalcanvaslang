# ============================================================
# DiGiCo Professional Audio — Standard Library Templates
# SD Series, Quantum Series, SD-Rack
# ============================================================

# --- SD Series ------------------------------------------------

template SD7 {
  meta {
    manufacturer: "DiGiCo"
    model: "SD7"
    category: "Console"
  }
  ports {
    Mic_In[1..12]: in(XLR) [analog, mic_level]
    Line_Out[1..12]: out(XLR) [analog, line_level]
    AES_In[1..6]: in(XLR) [AES3]
    AES_Out[1..6]: out(XLR) [AES3]
    MADI_A_Pri_In[1..64]: in(BNC_75) [MADI, primary]
    MADI_A_Pri_Out[1..64]: out(BNC_75) [MADI, primary]
    MADI_A_Sec_In[1..64]: in(BNC_75) [MADI, redundant]
    MADI_A_Sec_Out[1..64]: out(BNC_75) [MADI, redundant]
    MADI_B_Pri_In[1..64]: in(BNC_75) [MADI, primary]
    MADI_B_Pri_Out[1..64]: out(BNC_75) [MADI, primary]
    MADI_B_Sec_In[1..64]: in(BNC_75) [MADI, redundant]
    MADI_B_Sec_Out[1..64]: out(BNC_75) [MADI, redundant]
    MADI_C_Pri_In[1..64]: in(BNC_75) [MADI, primary]
    MADI_C_Pri_Out[1..64]: out(BNC_75) [MADI, primary]
    MADI_C_Sec_In[1..64]: in(BNC_75) [MADI, redundant]
    MADI_C_Sec_Out[1..64]: out(BNC_75) [MADI, redundant]
    MADI_D_Pri_In[1..64]: in(BNC_75) [MADI, primary]
    MADI_D_Pri_Out[1..64]: out(BNC_75) [MADI, primary]
    MADI_D_Sec_In[1..64]: in(BNC_75) [MADI, redundant]
    MADI_D_Sec_Out[1..64]: out(BNC_75) [MADI, redundant]
    Optocore_A_In: in(OpticalCon) [Optocore]
    Optocore_A_Out: out(OpticalCon) [Optocore]
    Optocore_B_In: in(OpticalCon) [Optocore]
    Optocore_B_Out: out(OpticalCon) [Optocore]
    WordClock_In: in(BNC_75) [WordClock]
    WordClock_Out: out(BNC_75) [WordClock]
  }
  bridge Mic_In -> MADI_A_Pri_Out
}

