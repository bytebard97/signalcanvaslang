# ============================================================
# DiGiCo Professional Audio — Standard Library Templates
# SD Series, Quantum Series, SD-Rack
# ============================================================

# --- SD Series ------------------------------------------------

template SD7 {
  meta {
    manufacturer: "DiGiCo"
    model: "SD7"
    category: "Console"
  }
  ports {
    Mic_In[1..12]: in(XLR) [analog, mic_level]
    Line_Out[1..12]: out(XLR) [analog, line_level]
    AES_In[1..6]: in(XLR) [AES3]
    AES_Out[1..6]: out(XLR) [AES3]
    MADI_A_Pri: io(BNC_75) [MADI, primary]
    MADI_A_Sec: io(BNC_75) [MADI, redundant]
    MADI_B_Pri: io(BNC_75) [MADI, primary]
    MADI_B_Sec: io(BNC_75) [MADI, redundant]
    MADI_C_Pri: io(BNC_75) [MADI, primary]
    MADI_C_Sec: io(BNC_75) [MADI, redundant]
    MADI_D_Pri: io(BNC_75) [MADI, primary]
    MADI_D_Sec: io(BNC_75) [MADI, redundant]
    Optocore_A: io(OpticalCon) [Optocore]
    Optocore_B: io(OpticalCon) [Optocore]
    WordClock_In: in(BNC_75) [WordClock]
    WordClock_Out: out(BNC_75) [WordClock]
  }
  bridge Mic_In -> MADI_A_Pri
}

