# ============================================================
# EVS — Replay Servers and Production Systems
# Standard library templates for EVS broadcast devices.
# ============================================================

# --- XT-VIA: Premium Replay Server --------------------------

template XT_VIA {
  meta {
    kind: "device"
    manufacturer: "EVS"
    model: "XT-VIA"
    category: "Replay Server"
  }
  ports {
    SDI_In[1..12]: in(BNC_75) [SDI, UHD]
    SDI_Out[1..12]: out(BNC_75) [SDI, UHD]
    Network_10G[1..2]: io(SFP) [Ethernet, GbE_10]
    Network_100G: io(SFP) [Ethernet, GbE_100]
    Ref_In: in(BNC_75) [BlackBurst, TriLevel]
    LAN: io(RJ45)
  }
  bridge SDI_In -> SDI_Out
}

# --- XT3: HD/SD Replay Server --------------------------------

template XT3 {
  meta {
    kind: "device"
    manufacturer: "EVS"
    model: "XT3"
    category: "Replay Server"
  }
  ports {
    # Up to 8 HD/SD-SDI channels (3G for 1080p)
    SDI_In[1..8]: in(BNC_75) [SDI, HD]
    SDI_Out[1..8]: out(BNC_75) [SDI, HD]
    SDI_Mon[1..8]: out(BNC_75) [SDI, HD]
    # Analog audio
    Audio_In[1..8]: in(XLR) [analog, line_level]
    Audio_Out[1..8]: out(XLR) [analog, line_level]
    Audio_Mon[1..4]: out(XLR) [analog, line_level]
    # Network and sync
    LAN: io(RJ45) [Ethernet]
    Ref_In: in(BNC_75) [BlackBurst, TriLevel]
  }
  bridge SDI_In -> SDI_Out
}
