# ============================================================
# NewTek (Vizrt) — IP-Native Production Systems
# Standard library templates for NewTek broadcast devices.
# ============================================================

# --- TriCaster 2 Elite: IP/SDI Production System -------------

template TriCaster_2_Elite {
  meta {
    manufacturer: "NewTek"
    model: "TriCaster 2 Elite"
    category: "Video Switcher"
  }
  ports {
    SDI_In[1..8]: in(BNC_75) [SDI, UHD]
    SDI_Out[1..8]: out(BNC_75) [SDI, UHD]
    HDMI_In[1..2]: in(HDMI) [UHD]
    HDMI_Out[1..2]: out(HDMI) [UHD]
    NDI_In[1..16]: in(virtual) [NDI]
    NDI_Out[1..16]: out(virtual) [NDI]
    Ref_In: in(BNC_75) [BlackBurst, TriLevel]
    LAN[1..2]: io(RJ45)
    Audio_In[1..4]: in(XLR) [analog, line_level]
    Audio_Out[1..4]: out(XLR) [analog, line_level]
  }
  bridge SDI_In -> SDI_Out
  bridge NDI_In -> SDI_Out
}
