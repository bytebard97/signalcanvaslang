# ============================================================
# Sony — Studio Cameras, CCUs, PTZ Cameras
# Standard library templates for Sony broadcast video devices.
# ============================================================

# --- HDC-3500: 4K CMOS Studio Camera (Camera Head) -----------

template HDC_3500 {
  meta {
    kind: "device"
    manufacturer: "Sony"
    model: "HDC-3500"
    category: "Camera"
  }
  ports {
    SDI_Out[1..2]: out(BNC_75) [SDI, HD]
    SDI_Mon: out(BNC_75) [SDI, HD]
    Test_Out: out(BNC_75) [analog, SD]
    Prompter_In: in(BNC_75) [SDI]
    CCU: io(LEMO)
    Mic_In[1..2]: in(XLR) [analog, mic_level, phantom_48V]
    Intercom[1..2]: io(XLR_5) [analog]
    Genlock_In: in(BNC_75) [BlackBurst, TriLevel]
    LAN: io(RJ45)
  }
  bridge Mic_In -> CCU
}

# --- HDC-5500: UHB 4K Studio Camera (Camera Head) ------------

template HDC_5500 {
  meta {
    kind: "device"
    manufacturer: "Sony"
    model: "HDC-5500"
    category: "Camera"
  }
  ports {
    SDI_Out[1..2]: out(BNC_75) [SDI, UHD]
    SDI_Mon: out(BNC_75) [SDI, HD]
    Test_Out: out(BNC_75) [analog, SD]
    Prompter_In: in(BNC_75) [SDI]
    CCU: io(LEMO)
