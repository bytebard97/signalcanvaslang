# ============================================================
# Evertz — Video Routers and Infrastructure
# Standard library templates for Evertz broadcast devices.
# ============================================================

# --- EQX16: Enterprise Hybrid Video/Audio/IP Router ----------

template EQX16 {
  meta {
    kind: "device"
    manufacturer: "Evertz"
    model: "EQX16"
    category: "Video Router"
  }
  ports {
    # 288x288 modular SDI routing (SD/HD/3G/6G/12G)
    # Actual I/O via card modules in 18-port increments
    Ref_In[1..2]: in(BNC_75) [BlackBurst, TriLevel]
    # X-Link monitoring outputs
    XLink_Out[1..9]: out(BNC_75) [SDI]
    # Control
    LAN: io(RJ45) [Ethernet]
  }
  slot IO_Slot[1..32]: EQX_IO_Card
}
