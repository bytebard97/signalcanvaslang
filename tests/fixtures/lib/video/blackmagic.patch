# ============================================================
# Blackmagic Design — Switchers, Routers, Recorders,
# Multiviewers, Sync, and Converters
# Standard library templates for Blackmagic broadcast devices.
# ============================================================

# --- ATEM Constellation 8K: Flagship Production Switcher ------

template ATEM_Constellation_8K {
  meta {
    kind: "device"
    manufacturer: "Blackmagic Design"
    model: "ATEM Constellation 8K"
    category: "Video Switcher"
  }
  ports {
    SDI_In[1..40]: in(BNC_75) [SDI, UHD]
    SDI_Out[1..24]: out(BNC_75) [SDI, UHD]
    MV_Out[1..4]: out(BNC_75) [SDI, UHD]
    MADI_In: in(BNC_75) [MADI]
    MADI_Out[1..2]: out(BNC_75) [MADI]
    Analog_In[1..2]: in(TRS) [analog, line_level]
    Analog_Out[1..2]: out(TRS) [analog, line_level]
    Talkback: io(XLR_5) [analog]
    Ref_In: in(BNC_75) [BlackBurst, TriLevel]
    Ref_Out: out(BNC_75) [BlackBurst, TriLevel]
    LAN: io(RJ45)
  }
  bridge SDI_In -> SDI_Out
  bridge SDI_In -> MV_Out
}

