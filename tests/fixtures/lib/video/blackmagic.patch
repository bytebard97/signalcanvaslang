# --- MultiView 16: 16-Input Multiviewer ----------------------

template MultiView_16 {
  meta {
    kind: "device"
    manufacturer: "Blackmagic Design"
    model: "MultiView 16"
    category: "Multiviewer"
  }
  ports {
    SDI_In[1..16]: in(BNC_75) [SDI, UHD]
    SDI_Loop[1..16]: out(BNC_75) [SDI, UHD]
    HD_SDI_Out[1..2]: out(BNC_75) [SDI, HD]
    SDI_6G_Out[1..2]: out(BNC_75) [SDI, UHD]
    HDMI_Out: out(HDMI) [UHD]
    LAN: io(RJ45)
  }
  bridge SDI_In -> SDI_Loop
  bridge SDI_In -> HD_SDI_Out
  bridge SDI_In -> SDI_6G_Out
  bridge SDI_In -> HDMI_Out
}

