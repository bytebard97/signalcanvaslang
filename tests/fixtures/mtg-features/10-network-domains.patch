# MTG Feature Test: network domain declarations
# Tests Dante and SoundGrid L2 network domain membership via the `network` construct.
# Covers: port-group membership, device-level membership, multiple domains, mixed protocols.

template Rio3224 {
  meta {
    manufacturer: "Yamaha"
    model: "Rio3224"
    category: "Stagebox"
  }
  ports {
    Dante_Pri_In[1..32]: in(etherCON) [Dante, primary]
    Dante_Pri_Out[1..32]: out(etherCON) [Dante, primary]
    Dante_Sec_In[1..32]: in(etherCON) [Dante, secondary]
    Dante_Sec_Out[1..32]: out(etherCON) [Dante, secondary]
    Mic_In[1..32]: in(XLR)
  }
  bridge Mic_In -> Dante_Pri_Out
}

template CL5 {
  meta {
    manufacturer: "Yamaha"
    model: "CL5"
    category: "Console"
  }
  ports {
    Dante_Pri_In[1..72]: in(etherCON) [Dante, primary]
    Dante_Pri_Out[1..24]: out(etherCON) [Dante, primary]
  }
}

template SG_Server {
  meta {
    manufacturer: "Waves"
    model: "eMotion LV1"
    category: "Console"
  }
  ports {
    SoundGrid_In[1..64]: in(etherCON) [SoundGrid]
    SoundGrid_Out[1..64]: out(etherCON) [SoundGrid]
  }
}

template SG_Impact {
  meta {
    manufacturer: "DiGiGrid"
    model: "MGB"
    category: "Stagebox"
  }
  ports {
    SoundGrid_In[1..32]: in(etherCON) [SoundGrid]
    SoundGrid_Out[1..32]: out(etherCON) [SoundGrid]
    Mic_In[1..32]: in(XLR)
  }
  bridge Mic_In -> SoundGrid_Out
}

instance Stage_Left is Rio3224 { location: "Stage Left" }
instance Stage_Right is Rio3224 { location: "Stage Right" }
instance FOH_Console is CL5 { location: "FOH" }
instance FOH_Waves is SG_Server { location: "FOH Rack" }
instance Stage_Impact is SG_Impact { location: "Stage" }

# Explicit L2 network domains — Cluster Provider B reads these directly.
# Two independent Dante fabrics; one SoundGrid fabric.

network Main_Dante {
  protocol: "Dante"
  label: "Main Dante Network"
  member Stage_Left.Dante_Pri
  member Stage_Right.Dante_Pri
  member FOH_Console.Dante_Pri
}

network FOH_SoundGrid {
  protocol: "SoundGrid"
  member FOH_Waves
  member Stage_Impact
}

connect Stage_Left.Dante_Pri_Out -> FOH_Console.Dante_Pri_In {
  cable: "Cat6a-SL"
}
connect Stage_Right.Dante_Pri_Out -> FOH_Console.Dante_Pri_In {
  cable: "Cat6a-SR"
}
