# MTG Feature Test: Internal mix buses with output destinations
# Source: MTG.json — FOH Engine mix buses routed to MADI snake outputs
# Demonstrates:
#   - bus label: field for display names with special chars (e.g. "PQ>MM")
#   - labeled single-destination outputs: output "Name": Port[n]
#   - labeled multi-destination outputs: output "Name": Port[n], Port[m]
#   - labeled unrouted outputs: output "Name"  (bus reserved, not yet cabled)

template Venue_FOH_Rack {
  meta {
    kind: "device"
    manufacturer: "AVID"
    model: "Venue FOH Rack"
  }
  ports {
    MADI_In[1..48]: in(BNC_75) [MADI]
    MADI_Out[1..48]: out(BNC_75) [MADI]
    LINE[1..8]: io(TRS_14)
  }
}

instance FOH_Engine is Venue_FOH_Rack {
  bus PA_Matrix {
    label: "PA Matrix"
    output "MADI_Out 9": MADI_Out[9]
    output "MADI_Out 10": MADI_Out[10]
  }
  bus Front_Fill_Matrix {
    label: "Front Fill Matrix"
    output "MADI_Out 11": MADI_Out[11]
  }
  bus Floor_Sub_Matrix {
    label: "Floor Sub Matrix"
    output "MADI_Out 12": MADI_Out[12]
  }
  bus PQ_MM {
    label: "PQ>MM"
    output "MADI_Out 1": MADI_Out[1]
    output "MADI_Out 2": MADI_Out[2]
  }
  bus PQ_Band {
    label: "PQ>Band"
    output "MADI_Out 3": MADI_Out[3]
    output "MADI_Out 4": MADI_Out[4]
  }
  bus PQ_Vox {
    label: "PQ>Vox"
    output "MADI_Out 5": MADI_Out[5]
  }
  bus PQ_MC {
    label: "PQ>MC"
    output "MADI_Out 6": MADI_Out[6]
  }
  bus PQ_PGM {
    label: "PQ>PGM"
    output "MADI_Out 7": MADI_Out[7]
    output "MADI_Out 8": MADI_Out[8]
  }
  bus VoxVerb_LP {
    label: "Vox Verb LP"
    output "MADI_Out 13": MADI_Out[13]
  }
  bus DrumVerb_LP {
    label: "Drum Verb LP"
    output "MADI_Out 14": MADI_Out[14]
  }
  # Multi-destination: one mix sent to both MADI snakes simultaneously
  bus Record_Mix {
    label: "Record"
    input: MADI_In[1]
    output "Record L": MADI_Out[15], MADI_Out[31]
    output "Record R": MADI_Out[16], MADI_Out[32]
  }
  # Unrouted: bus reserved in the console, destination not yet cabled
  bus Broadcast_Feed {
    label: "Broadcast"
    input: MADI_In[2]
    output "Broadcast L"
    output "Broadcast R"
  }
}
