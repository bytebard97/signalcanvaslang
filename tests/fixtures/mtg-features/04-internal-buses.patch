# MTG Feature Test: Internal mix buses with output destinations
# Source: MTG.json — FOH Engine mix buses routed to MADI snake outputs

template Venue_FOH_Rack {
  meta {
    manufacturer: "AVID"
    model: "Venue FOH Rack"
  }
  ports {
    MADI_In[1..48]: in(BNC_75) [MADI]
    MADI_Out[1..48]: out(BNC_75) [MADI]
    LINE[1..8]: io(TRS_14)
  }
}

instance FOH_Engine is Venue_FOH_Rack {
  bus PA_Matrix {
    output: MADI_Out[9]
    output: MADI_Out[10]
  }
  bus Front_Fill_Matrix {
    output: MADI_Out[11]
  }
  bus Floor_Sub_Matrix {
    output: MADI_Out[12]
  }
  bus PQ_MM {
    output: MADI_Out[1]
    output: MADI_Out[2]
  }
  bus PQ_Band {
    output: MADI_Out[3]
    output: MADI_Out[4]
  }
  bus PQ_Vox {
    output: MADI_Out[5]
  }
  bus PQ_MC {
    output: MADI_Out[6]
  }
  bus PQ_PGM {
    output: MADI_Out[7]
    output: MADI_Out[8]
  }
  bus VoxVerb_LP {
    output: MADI_Out[13]
  }
  bus DrumVerb_LP {
    output: MADI_Out[14]
  }
}
