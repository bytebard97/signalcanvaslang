# MTG Feature Test: AES67 interoperability
# Tests dante_chipset meta, aes67_mode, multicast_prefix, stream declarations

template Shure_MXA910 {
  meta {
    kind: "device"
    manufacturer: "Shure"
    model: "MXA910"
    dante_chipset: "Brooklyn_II"
  }
  ports {
    Dante_Pri_In[1..10]: in(etherCON) [Dante, primary]
    Dante_Pri_Out[1..10]: out(etherCON) [Dante, primary]
  }
}

template QSys_Core {
  meta {
    kind: "device"
    manufacturer: "QSC"
    model: "Core 110f"
  }
  ports {
    AES67_In[1..8]: in(RJ45) [AES67]
    AES67_Out[1..8]: out(RJ45) [AES67]
  }
}

instance Ceiling_Mic is Shure_MXA910 {
  aes67_mode: true
  multicast_prefix: 71
}

instance DSP is QSys_Core {
  aes67_mode: true
  multicast_prefix: 71
}

connect Ceiling_Mic.Dante_Pri_Out[1] -> DSP.AES67_In[1] {
  cable: "Cat6a_AES67"
}

stream Ceiling_AES67 {
  source: Ceiling_Mic.Dante_Pri_Out
  channels: 8
  protocol: "AES67"
}
