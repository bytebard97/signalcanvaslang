# Allen & Heath dLive DM64 Stage Rack → Yamaha CL5 FOH Console
# Stage Left install — Dante Primary interconnect

# ─── Templates ───────────────────────────────────────────────────────────────

template DM64 {
  meta {
    kind: "device"
    manufacturer: "Allen & Heath"
    model: "dLive DM64"
    category: "Stagebox"
  }
  ports {
    # Analogue I/O
    Mic_In[1..64]:    in(XLR)  [Analogue]
    Line_Out[1..32]:  out(XLR) [Analogue]

    # Dante Primary (etherCON)
    Dante_Pri_In[1..128]:  in(etherCON)  [Dante, primary]
    Dante_Pri_Out[1..128]: out(etherCON) [Dante, primary]

    # GigaACE — proprietary A&H ring (SFP)
    GigaACE_Pri_A: io(SFP) [GigaACE, primary]
    GigaACE_Pri_B: io(SFP) [GigaACE, primary]
    GigaACE_Sec_A: io(SFP) [GigaACE, secondary, redundant]
    GigaACE_Sec_B: io(SFP) [GigaACE, secondary, redundant]
  }

  # Internal bridge: mic preamps → Dante Primary output
  bridge Mic_In -> Dante_Pri_Out

  # Internal bridge: Dante Primary input → line outputs
  bridge Dante_Pri_In -> Line_Out
}

template CL5 {
  meta {
    kind: "device"
    manufacturer: "Yamaha"
    model: "CL5"
    category: "Console"
  }
  ports {
    Dante_Pri_In[1..72]:  in(etherCON)  [Dante, primary]
    Dante_Pri_Out[1..24]: out(etherCON) [Dante, primary]
  }
}

# ─── Instances ────────────────────────────────────────────────────────────────

instance Stage_Rack_SL is DM64 {
  location: "Stage Left"
  ip: "192.168.10.20"
}

instance FOH_Console is CL5 {
  location: "Front of House"
}

# ─── Connections ─────────────────────────────────────────────────────────────

# Stage_Rack_SL Dante Pri Out [1..64] → FOH_Console Dante Pri In [1..64]
connect Stage_Rack_SL.Dante_Pri_Out[1..64] -> FOH_Console.Dante_Pri_In[1..64] {
  cable: "GbE_SL_Dante_Pri"
  length: "35m"
}

# FOH_Console Dante Pri Out [1..24] → Stage_Rack_SL Dante Pri In [1..24]
connect FOH_Console.Dante_Pri_Out[1..24] -> Stage_Rack_SL.Dante_Pri_In[1..24] {
  cable: "GbE_SL_Dante_Pri"
  length: "35m"
}
